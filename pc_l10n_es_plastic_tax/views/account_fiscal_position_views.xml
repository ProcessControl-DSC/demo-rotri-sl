<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="fiscal_position_form_plastic" model="ir.ui.view">
        <field name="name">account.fiscal.position.form.plastic</field>
        <field name="model">account.fiscal.position</field>
        <field name="inherit_id" ref="account.view_account_position_form"/>
        <field name="arch" type="xml">
            <field name="company_id" position="after">
                <field name="plastic_exempt"/>
                <field name="plastic_exempt_reason" invisible="not plastic_exempt"/>
            </field>
        </field>
    </record>
</odoo>
