<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_partner_form_plastic" model="ir.ui.view">
        <field name="name">res.partner.form.plastic.tax</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='sales_purchases']//group" position="inside">
                <group string="Impuesto plástico (Ley 7/2022)">
                    <field name="plastic_tax_customer_mode"/>
                    <field name="plastic_tax_supplier_mode"/>
                </group>
            </xpath>
        </field>
    </record>
</odoo>
