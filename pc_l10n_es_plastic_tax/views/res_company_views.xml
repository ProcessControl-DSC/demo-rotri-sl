<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_company_form_plastic" model="ir.ui.view">
        <field name="name">res.company.form.plastic.tax</field>
        <field name="model">res.company</field>
        <field name="inherit_id" ref="base.view_company_form"/>
        <field name="arch" type="xml">
            <field name="vat" position="after">
                <field name="plastic_tax_cip"/>
            </field>
            <xpath expr="//sheet" position="inside">
                <group string="Impuesto del plástico (Ley 7/2022)" col="2">
                    <group>
                        <field name="plastic_tax_rate"/>
                        <field name="plastic_tax_minimis_kg"/>
                        <field name="plastic_tax_period"/>
                        <field name="plastic_mo_registration"/>
                        <field name="plastic_snapshot_interval"/>
                    </group>
                    <group>
                        <field name="plastic_tax_account_output_id"/>
                        <field name="plastic_tax_account_expense_id"/>
                        <field name="plastic_tax_account_cost_id"/>
                        <field name="plastic_tax_account_income_id"/>
                        <field name="plastic_kg_from_weight"/>
                        <field name="plastic_weight_field_id"
                               invisible="not plastic_kg_from_weight"/>
                        <field name="plastic_exempt_from_fiscal_pos"/>
                        <field name="plastic_first_seller"/>
                        <field name="plastic_hide_counterpart_pdf"/>
                    </group>
                </group>
            </xpath>
        </field>
    </record>
</odoo>
